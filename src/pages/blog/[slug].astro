---
/**
 * Single WordPress blog post
 * URL: /blog/[slug]
 */
export const prerender = false;

import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { getPost, getPosts, getFeaturedImage, getPostCategories, formatWPDate, stripHtml } from '@/lib/wordpress';
import siteConfig from '@/config/site.config';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/blog');

const post = await getPost(slug);
if (!post) return Astro.redirect('/blog');

const img = getFeaturedImage(post);
const cats = getPostCategories(post);
const authorName = post._embedded?.author?.[0]?.name || siteConfig.name;

const canonicalUrl = `${siteConfig.url}/blog/${post.slug}`;
const seoTitle = post.yoast_head_json?.title || `${stripHtml(post.title.rendered)} | Hutama Bore Pile`;
const seoDesc = post.yoast_head_json?.description || stripHtml(post.excerpt.rendered).slice(0, 160);
const ogImage = post.yoast_head_json?.og_image?.[0]?.url || img?.src || `${siteConfig.url}/og-default.svg`;

// Recent posts for sidebar/related
const recentPosts = await getPosts({ per_page: 4, exclude: String(post.id) });

// Schema markup
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: stripHtml(post.title.rendered),
  description: seoDesc,
  url: canonicalUrl,
  image: ogImage,
  datePublished: post.date,
  dateModified: post.modified,
  author: {
    '@type': 'Person',
    name: authorName,
  },
  publisher: {
    '@type': 'Organization',
    name: siteConfig.name,
    url: siteConfig.url,
    logo: {
      '@type': 'ImageObject',
      url: `${siteConfig.url}/favicon.svg`,
    },
  },
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonicalUrl,
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Beranda', item: siteConfig.url },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteConfig.url}/blog` },
    { '@type': 'ListItem', position: 3, name: stripHtml(post.title.rendered), item: canonicalUrl },
  ],
};
---

<PageLayout title={seoTitle} description={seoDesc}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDesc} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={post.date} />
    <meta property="article:modified_time" content={post.modified} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <!-- Breadcrumb -->
  <nav class="bg-background border-b border-border" aria-label="Breadcrumb">
    <div class="mx-auto max-w-6xl px-6 py-3">
      <ol class="flex items-center gap-2 text-sm text-foreground-muted flex-wrap">
        <li><a href="/" class="hover:text-brand-500 transition-colors">Beranda</a></li>
        <li><Icon name="chevron-right" size="sm" class="text-foreground-muted/50" /></li>
        <li><a href="/blog" class="hover:text-brand-500 transition-colors">Blog</a></li>
        <li><Icon name="chevron-right" size="sm" class="text-foreground-muted/50" /></li>
        <li class="text-foreground font-medium truncate max-w-[200px]" set:html={post.title.rendered} />
      </ol>
    </div>
  </nav>

  <!-- Article -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-10 lg:grid-cols-[1fr_320px] lg:gap-12 items-start">

        <!-- Main content -->
        <article>
          <!-- Header -->
          <header class="mb-8">
            {cats.length > 0 && (
              <div class="flex flex-wrap gap-2 mb-4">
                {cats.map((cat) => (
                  <Badge variant="brand" pill>{cat}</Badge>
                ))}
              </div>
            )}
            <h1 class="font-display text-3xl md:text-4xl font-bold text-foreground leading-tight mb-4" set:html={post.title.rendered} />
            <div class="flex items-center gap-4 text-sm text-foreground-muted">
              <span class="flex items-center gap-1.5">
                <Icon name="user" size="sm" />
                {authorName}
              </span>
              <span class="flex items-center gap-1.5">
                <Icon name="calendar" size="sm" />
                <time datetime={post.date}>{formatWPDate(post.date)}</time>
              </span>
              {post.modified !== post.date && (
                <span class="flex items-center gap-1.5">
                  <Icon name="refresh-cw" size="sm" />
                  Diperbarui: <time datetime={post.modified}>{formatWPDate(post.modified)}</time>
                </span>
              )}
            </div>
          </header>

          <!-- Featured image -->
          {img && (
            <div class="mb-8 overflow-hidden rounded-2xl aspect-video bg-background-tertiary">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-full object-cover"
                width="800"
                height="450"
              />
            </div>
          )}

          <!-- Content -->
          <div class="prose prose-sm md:prose max-w-none text-foreground-muted wp-content" set:html={post.content.rendered} />

          <!-- Share / CTA -->
          <div class="mt-10 pt-8 border-t border-border">
            <Card padding="lg" class="bg-brand-500/5 border-brand-500/20">
              <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
                <div class="flex-1">
                  <h3 class="font-semibold text-foreground mb-1">Butuh Jasa Bore Pile?</h3>
                  <p class="text-sm text-foreground-muted">Konsultasi gratis dengan tim Hutama Bore Pile sekarang.</p>
                </div>
                <Button href="https://wa.me/6281328048030" target="_blank" rel="noopener noreferrer" class="cta-btn-brand shrink-0">
                  <Icon name="message-circle" size="sm" />
                  WhatsApp
                </Button>
              </div>
            </Card>
          </div>
        </article>

        <!-- Sidebar -->
        <aside class="space-y-6 lg:sticky lg:top-24">
          <!-- Contact card -->
          <Card variant="elevated" padding="lg">
            <h3 class="font-display text-base font-bold text-foreground mb-4">Konsultasi Gratis</h3>
            <div class="space-y-3">
              <a href="https://wa.me/6281328048030" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 p-3 rounded-xl bg-brand-500/5 border border-brand-500/20 hover:border-brand-500/50 transition-colors group">
                <div class="w-9 h-9 rounded-lg bg-brand-500/10 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="message-circle" size="sm" />
                </div>
                <div>
                  <p class="text-sm font-semibold text-foreground">WhatsApp</p>
                  <p class="text-xs text-foreground-muted">0813-2804-803</p>
                </div>
                <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors ml-auto" />
              </a>
              <a href="mailto:hutamaborepile@gmail.com" class="flex items-center gap-3 p-3 rounded-xl bg-background-tertiary border border-border hover:border-brand-500/30 transition-colors group">
                <div class="w-9 h-9 rounded-lg bg-background flex items-center justify-center text-foreground-muted shrink-0">
                  <Icon name="mail" size="sm" />
                </div>
                <div>
                  <p class="text-sm font-semibold text-foreground">Email</p>
                  <p class="text-xs text-foreground-muted truncate">hutamaborepile@gmail.com</p>
                </div>
              </a>
            </div>
          </Card>

          <!-- Recent posts -->
          {recentPosts.length > 0 && (
            <Card variant="elevated" padding="lg">
              <h3 class="font-display text-base font-bold text-foreground mb-4">Artikel Terbaru</h3>
              <div class="space-y-3">
                {recentPosts.map((rp) => {
                  const rpImg = getFeaturedImage(rp);
                  return (
                    <a href={`/blog/${rp.slug}`} class="flex items-start gap-3 group">
                      {rpImg ? (
                        <img src={rpImg.src} alt={rpImg.alt} class="w-14 h-14 rounded-lg object-cover shrink-0" loading="lazy" width="56" height="56" />
                      ) : (
                        <div class="w-14 h-14 rounded-lg bg-brand-500/10 flex items-center justify-center shrink-0">
                          <Icon name="file-text" size="sm" class="text-brand-500/50" />
                        </div>
                      )}
                      <div class="min-w-0">
                        <p class="text-sm font-medium text-foreground group-hover:text-brand-500 transition-colors leading-snug line-clamp-2" set:html={rp.title.rendered} />
                        <time class="text-xs text-foreground-muted mt-1 block" datetime={rp.date}>{formatWPDate(rp.date)}</time>
                      </div>
                    </a>
                  );
                })}
              </div>
              <Button variant="outline" href="/blog" class="w-full mt-4">
                Semua Blog
                <Icon name="arrow-right" size="sm" />
              </Button>
            </Card>
          )}
        </aside>
      </div>
    </div>
  </section>
</PageLayout>

<style is:global>
  .wp-content h2 { font-family: var(--font-display); font-size: 1.5rem; font-weight: 700; color: var(--color-foreground); margin-top: 2rem; margin-bottom: 1rem; }
  .wp-content h3 { font-family: var(--font-display); font-size: 1.25rem; font-weight: 700; color: var(--color-foreground); margin-top: 1.5rem; margin-bottom: 0.75rem; }
  .wp-content p  { margin-bottom: 1rem; line-height: 1.75; }
  .wp-content ul { list-style-type: disc; list-style-position: inside; margin-bottom: 1rem; }
  .wp-content ul li { margin-bottom: 0.25rem; }
  .wp-content ol { list-style-type: decimal; list-style-position: inside; margin-bottom: 1rem; }
  .wp-content ol li { margin-bottom: 0.25rem; }
  .wp-content a  { color: var(--color-brand-500); text-decoration: underline; text-underline-offset: 2px; }
  .wp-content a:hover { color: var(--color-brand-400); }
  .wp-content img { border-radius: 0.75rem; margin-top: 1.5rem; margin-bottom: 1.5rem; width: 100%; }
  .wp-content blockquote { border-left: 4px solid var(--color-brand-500); padding-left: 1rem; font-style: italic; color: var(--color-foreground-muted); margin-top: 1rem; margin-bottom: 1rem; }
  .wp-content table { width: 100%; border-collapse: collapse; font-size: 0.875rem; margin-bottom: 1rem; }
  .wp-content th { background-color: var(--color-background-tertiary); font-weight: 600; color: var(--color-foreground); padding: 0.5rem; border: 1px solid var(--color-border); text-align: left; }
  .wp-content td { padding: 0.5rem; border: 1px solid var(--color-border); }
  .wp-content pre { background: var(--color-background-secondary); border: 1px solid var(--color-border); padding: 1rem; border-radius: 0.5rem; overflow-x: auto; margin-bottom: 1rem; }
  .wp-content code { background: var(--color-background-tertiary); padding: 0.125rem 0.375rem; border-radius: 0.25rem; font-size: 0.875em; }
  .wp-content pre code { background: none; padding: 0; }
</style>
