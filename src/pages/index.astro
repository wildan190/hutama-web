---
import LandingLayout from '@/layouts/LandingLayout.astro';
import { Hero } from '@/components/hero';
import Button from '@/components/ui/form/Button/Button.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import BlogCard from '@/components/blog/BlogCard.astro';
import ImageCtaBand from '@/components/patterns/ImageCtaBand.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => {
    if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
    return b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf();
  })
  .slice(0, 3);

const waNumber = '6281328048030';
const waLink = `https://wa.me/${waNumber}`;
---

<LandingLayout
  title="Kontraktor Jasa Bore Pile (Strauss Pile) Harga Murah | Hutama Bore Pile"
  description="Hutama Bore Pile melayani jasa bore pile profesional untuk rumah, gedung, gudang, pabrik, dan proyek konstruksi di seluruh Pulau Jawa. Harga kompetitif, tenaga berpengalaman."
  image="/og-default.svg"
  includeProfessionalServiceSchema={true}
>
  <!-- Hero -->
  <Hero layout="centered" size="xl" class="hero-dark-gradient" showScrollIndicator fullHeight>
    <Badge slot="badge" variant="brand" pill pulse class="dark:text-brand-200">Konsultasi Gratis</Badge>

    <h1 slot="title" class="!text-[clamp(1.8rem,8vw,3rem)] sm:!text-5xl md:!text-6xl lg:!text-7xl">
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">Jasa Bore Pile Profesional</span><br />
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">untuk Pondasi Bangunan</span><br />
      <span class="text-brand-600 dark:text-foreground [-webkit-text-fill-color:currentColor]">di Pulau Jawa</span>
    </h1>

    <p slot="description">
      Melayani jasa bore pile untuk rumah, gudang, ruko, gedung, pabrik, jembatan, dan proyek konstruksi lainnya dengan tenaga berpengalaman dan harga kompetitif.
    </p>

    <Fragment slot="actions">
      <Button size="lg" href={waLink} target="_blank" rel="noopener noreferrer">
        <Icon name="message-circle" size="sm" />
        Hubungi via WhatsApp
        <Icon name="arrow-right" size="sm" />
      </Button>
      <Button size="lg" variant="outline" href="/contact">
        Konsultasi Gratis
        <Icon name="arrow-right" size="sm" />
      </Button>
    </Fragment>
  </Hero>

  <!-- Quick Trust -->
  <section class="relative z-10 py-8 bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-center">
        <div class="flex flex-col items-center gap-2 p-4">
          <Icon name="award" class="w-8 h-8 text-brand-500" />
          <p class="text-sm font-semibold text-foreground">Berpengalaman</p>
        </div>
        <div class="flex flex-col items-center gap-2 p-4">
          <Icon name="tag" class="w-8 h-8 text-brand-500" />
          <p class="text-sm font-semibold text-foreground">Harga Kompetitif</p>
        </div>
        <div class="flex flex-col items-center gap-2 p-4">
          <Icon name="zap" class="w-8 h-8 text-brand-500" />
          <p class="text-sm font-semibold text-foreground">Survey Cepat</p>
        </div>
        <div class="flex flex-col items-center gap-2 p-4">
          <Icon name="map-pin" class="w-8 h-8 text-brand-500" />
          <p class="text-sm font-semibold text-foreground">Area Seluruh Jawa</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Masalah Customer -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Kenali Masalahnya</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Sedang Mencari Jasa Bore Pile yang Tepat?
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          Hutama Bore Pile siap membantu pengerjaan pondasi bore pile secara profesional dan tepat waktu.
        </p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { icon: 'alert-triangle', text: 'Tanah labil dan rawan amblas' },
          { icon: 'x-circle', text: 'Pondasi rawan retak atau bergeser' },
          { icon: 'search', text: 'Sulit cari kontraktor terpercaya' },
          { icon: 'trending-up', text: 'Takut biaya membengkak' },
          { icon: 'clock', text: 'Khawatir pengerjaan lama' },
          { icon: 'check-circle', text: 'Butuh solusi pondasi yang tepat' },
        ].map((item) => (
          <Card hover data-reveal class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name={item.icon} size="sm" />
            </div>
            <p class="text-sm font-medium text-foreground">{item.text}</p>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Layanan -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Layanan Kami</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Layanan Jasa Bore Pile
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          Kami menyediakan berbagai layanan pondasi bore pile untuk kebutuhan konstruksi Anda.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        <Card hover href="/layanan" class="group flex flex-col" data-reveal>
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="drill" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Jasa Bore Pile Straus Pile</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Pengerjaan pondasi straus pile manual untuk berbagai kebutuhan konstruksi. Cocok untuk area dengan akses terbatas dan proyek skala menengah.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                Selengkapnya <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>
        <Card hover href="/layanan" class="group flex flex-col" data-reveal data-reveal-delay="1">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="settings" size="sm" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Jasa Bore Pile Mesin Mini Crane</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Pengerjaan bore pile menggunakan mesin mini crane untuk proyek yang membutuhkan kedalaman lebih dan kapasitas beban lebih besar.
              </p>
              <span class="inline-flex items-center gap-1 text-sm font-medium text-brand-500 mt-3 group-hover:gap-2 transition-all">
                Selengkapnya <Icon name="arrow-right" size="sm" />
              </span>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- Keunggulan -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Keunggulan</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Kenapa Memilih Hutama Bore Pile?
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { icon: 'users', title: 'Tenaga Berpengalaman', desc: 'Tim kami berpengalaman dalam berbagai proyek pondasi bore pile.' },
          { icon: 'settings', title: 'Mesin Lengkap', desc: 'Didukung peralatan lengkap dan modern untuk hasil optimal.' },
          { icon: 'zap', title: 'Pengerjaan Cepat', desc: 'Proses pengerjaan efisien dengan perencanaan yang matang.' },
          { icon: 'tag', title: 'Harga Transparan', desc: 'Penawaran harga jelas dan menyesuaikan kebutuhan proyek.' },
          { icon: 'map-pin', title: 'Survey Lokasi', desc: 'Tim kami siap survey lokasi sebelum pengerjaan dimulai.' },
          { icon: 'message-circle', title: 'Konsultasi Gratis', desc: 'Konsultasi kebutuhan pondasi tanpa biaya apapun.' },
          { icon: 'globe', title: 'Area Seluruh Jawa', desc: 'Melayani seluruh kota dan kabupaten di Pulau Jawa.' },
          { icon: 'layers', title: 'Proyek Kecil & Besar', desc: 'Siap menangani proyek rumah hingga gedung bertingkat.' },
        ].map((item, i) => (
          <Card hover data-reveal data-reveal-delay={String(i % 4)}>
            <div class="flex flex-col items-center text-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name={item.icon} size="sm" />
              </div>
              <div>
                <h3 class="text-sm font-semibold text-foreground">{item.title}</h3>
                <p class="text-xs text-foreground-muted leading-relaxed mt-1">{item.desc}</p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Area Layanan -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Area Layanan</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Area Layanan Jasa Bore Pile di Pulau Jawa
        </h2>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto">
          Kami melayani seluruh kota dan kabupaten di Pulau Jawa.
        </p>
      </div>
      <div class="flex flex-wrap gap-2 justify-center" data-reveal>
        {[
          'Surabaya','Sidoarjo','Gresik','Malang','Mojokerto','Pasuruan',
          'Jakarta','Bekasi','Bogor','Depok','Tangerang','Bandung',
          'Semarang','Yogyakarta','Solo','Madiun','Kediri','Blitar',
          'Jember','Banyuwangi','Probolinggo','Lumajang',
        ].map((kota) => (
          <Badge variant="brand" pill>{kota}</Badge>
        ))}
        <Badge variant="brand" pill>dan seluruh Pulau Jawa</Badge>
      </div>
      <div class="text-center">
        <Button variant="outline" href="/contact">
          Tanyakan Area Anda
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
    </div>
  </section>

  <!-- Proses Kerja -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Cara Kerja</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Proses Pengerjaan Bore Pile
        </h2>
      </div>
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {[
          { step: '1', title: 'Konsultasi', desc: 'Diskusikan kebutuhan pondasi proyek Anda bersama tim kami secara gratis.' },
          { step: '2', title: 'Survey Lokasi', desc: 'Tim kami melakukan pengecekan langsung ke lokasi proyek.' },
          { step: '3', title: 'Analisa Data Tanah', desc: 'Analisa data penyelidikan tanah untuk menentukan spesifikasi bore pile.' },
          { step: '4', title: 'Penawaran Harga', desc: 'Kami berikan quotation yang transparan sesuai kebutuhan proyek.' },
          { step: '5', title: 'Pengerjaan', desc: 'Proses pengeboran dan pengecoran pondasi bore pile oleh tim berpengalaman.' },
          { step: '6', title: 'Quality Control', desc: 'Finishing dan pengecekan kualitas untuk memastikan hasil terbaik.' },
        ].map((item, i) => (
          <Card hover data-reveal data-reveal-delay={String(i % 3)}>
            <div class="flex flex-col items-center text-center gap-3">
              <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 font-bold text-base shrink-0">
                {item.step}
              </div>
              <div>
                <h3 class="text-base font-semibold text-foreground">{item.title}</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">{item.desc}</p>
              </div>
            </div>
          </Card>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimoni -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>Testimoni</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          Testimoni Klien
        </h2>
      </div>
      <div class="grid gap-6 md:grid-cols-2">
        <Card variant="elevated" padding="lg" hover data-reveal>
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500" role="img" aria-label="5 dari 5 bintang">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              "Pengerjaan bore pile untuk gudang kami di Surabaya berjalan lancar dan tepat waktu. Tim Hutama Bore Pile sangat profesional dan responsif. Harga juga sesuai penawaran awal, tidak ada biaya tambahan yang mengejutkan."
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">B</div>
              <div>
                <p class="text-sm font-semibold text-foreground">Budi Santoso</p>
                <p class="text-xs text-foreground-muted">Pemilik Gudang, Surabaya</p>
              </div>
            </div>
          </div>
        </Card>
        <Card variant="elevated" padding="lg" hover data-reveal data-reveal-delay="1">
          <div class="flex flex-col h-full gap-4">
            <div class="flex gap-1 text-brand-500" role="img" aria-label="5 dari 5 bintang">
              {[...Array(5)].map(() => (
                <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>
            <blockquote class="flex-1 text-foreground-muted leading-relaxed">
              "Kami menggunakan jasa Hutama Bore Pile untuk proyek rumah tinggal di Sidoarjo. Survey lokasi cepat, penawaran harga transparan, dan hasil pengerjaan memuaskan. Sangat direkomendasikan."
            </blockquote>
            <div class="flex items-center gap-3 pt-4 border-t border-border">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-brand-500/30 to-brand-500/10 flex items-center justify-center text-brand-500 font-bold text-sm shrink-0">A</div>
              <div>
                <p class="text-sm font-semibold text-foreground">Ahmad Fauzi</p>
                <p class="text-xs text-foreground-muted">Kontraktor, Sidoarjo</p>
              </div>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <Badge variant="brand" pill>FAQ</Badge>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
          FAQ Jasa Bore Pile
        </h2>
      </div>
      <div class="max-w-3xl mx-auto w-full">
        <Card variant="elevated" padding="lg" data-reveal>
          {[
            { q: 'Apa itu bore pile?', a: 'Bore pile adalah jenis pondasi dalam yang dibuat dengan cara mengebor tanah hingga kedalaman tertentu, kemudian diisi dengan tulangan besi dan beton. Digunakan untuk bangunan di atas tanah labil atau bangunan bertingkat.' },
            { q: 'Berapa harga jasa bore pile?', a: 'Harga jasa bore pile bervariasi tergantung kedalaman, diameter, jumlah titik, dan lokasi proyek. Hubungi kami untuk mendapatkan penawaran harga yang sesuai dengan kebutuhan proyek Anda.' },
            { q: 'Kapan pondasi bore pile digunakan?', a: 'Bore pile digunakan ketika kondisi tanah labil, bangunan bertingkat, beban bangunan besar, atau ketika pondasi dangkal tidak memadai untuk menopang beban konstruksi.' },
            { q: 'Berapa kedalaman bore pile?', a: 'Kedalaman bore pile disesuaikan dengan kondisi tanah dan kebutuhan struktur bangunan. Umumnya berkisar antara 6 hingga 20 meter atau lebih, tergantung hasil penyelidikan tanah.' },
            { q: 'Apakah melayani seluruh Pulau Jawa?', a: 'Ya, Hutama Bore Pile melayani seluruh kota dan kabupaten di Pulau Jawa, termasuk Surabaya, Sidoarjo, Gresik, Malang, Jakarta, Bandung, Semarang, Yogyakarta, dan sekitarnya.' },
            { q: 'Apakah bisa survey lokasi?', a: 'Ya, tim kami siap melakukan survey lokasi untuk menilai kondisi tanah dan memberikan rekomendasi pondasi yang tepat sesuai kebutuhan proyek Anda.' },
          ].map((item, i) => (
            <details class="border-b border-border last:border-0" name="faq-borepile">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                {item.q}
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">{item.a}</div>
            </details>
          ))}
        </Card>
      </div>
    </div>
  </section>

  <!-- Blog -->
  {posts.length > 0 && (
    <section class="relative z-10 py-[var(--space-section-md)] bg-background-secondary border-t border-border">
      <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
        <div class="flex flex-col items-center gap-6 text-center" data-reveal>
          <Badge variant="brand" pill>Blog</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Informasi Seputar Bore Pile
          </h2>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {posts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              href={`/blog/${post.id.replace('en/', '')}`}
              publishedAt={post.data.publishedAt}
              tags={post.data.tags}
              author={post.data.author}
              image={post.data.image}
              svgSlug={post.data.svgSlug}
            />
          ))}
        </div>
        <div class="flex justify-center">
          <Button variant="outline" href="/blog">
            Lihat Semua Blog
            <Icon name="arrow-right" size="sm" />
          </Button>
        </div>
      </div>
    </section>
  )}

  <!-- CTA Besar -->
  <section class="relative z-10 py-[var(--space-section-md)] bg-background border-t border-border">
    <ImageCtaBand
      backgroundImage="https://images.unsplash.com/photo-1748956628042-b73331e0b479?w=1920&h=800&fit=crop&q=80&auto=format"
      imageAlt="Pekerja konstruksi di lokasi pembangunan gedung dengan tower crane"
    >
      <Badge variant="brand" pill class="mb-6">Hubungi Kami</Badge>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Konsultasikan Kebutuhan Bore Pile Anda Sekarang
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        Tim Hutama Bore Pile siap membantu survey lokasi, konsultasi, dan penawaran terbaik untuk proyek Anda.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <Button size="lg" href={waLink} target="_blank" rel="noopener noreferrer" class="hero-btn-brand">
          <Icon name="message-circle" size="sm" />
          WhatsApp: 0813-2804-803
        </Button>
        <Button size="lg" variant="outline" href="/contact">
          Kirim Pesan
          <Icon name="arrow-right" size="sm" />
        </Button>
      </div>
