---
/**
 * Logo Component
 *
 * Renders the Hutama Bore Pile logo
 */
import { cn } from '@/lib/cn';
import siteConfig from '@/config/site.config';

interface Props {
  /** Size preset */
  size?: 'sm' | 'md' | 'lg' | 'xl' | '2xl';
  /** Force dark mode logo (for dark backgrounds) — no-op here, kept for API compat */
  forceDark?: boolean;
  /** Use full logo instead of logomark — no-op here, kept for API compat */
  variant?: 'logomark' | 'full';
  /** Additional CSS classes */
  class?: string;
  /** Override the displayed letter (e.g. for author avatars). Defaults to first letter of site name. */
  letter?: string;
}

const {
  size = 'md',
  class: className,
} = Astro.props;

const sizeClasses: Record<string, { box: string; radius: string }> = {
  sm:    { box: 'w-5 h-5',  radius: 'rounded-[4px]' },
  md:    { box: 'w-6 h-6',  radius: 'rounded-[5px]' },
  lg:    { box: 'w-8 h-8',  radius: 'rounded-[6px]' },
  xl:    { box: 'w-12 h-12', radius: 'rounded-[8px]' },
  '2xl': { box: 'w-24 h-24', radius: 'rounded-[14px]' },
};

const { box, radius } = sizeClasses[size] ?? sizeClasses.md;
---

<img
  src="/assets/img/Logo Hutama Bore Pile.webp"
  alt={siteConfig.branding.logo.alt}
  class={cn(
    'inline-flex items-center justify-center shrink-0 object-contain',
    box, radius,
    className
  )}
  loading="eager"
/>
