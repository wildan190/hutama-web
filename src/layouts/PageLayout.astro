---
/**
 * PageLayout
 * Layout wrapper for standard content pages (non-landing)
 * Uses Header + Footer with content page configuration
 */
import BaseLayout from './BaseLayout.astro';
import Header from '@/components/layout/Header.astro';
import Footer from '@/components/layout/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  noindex?: boolean;
  nofollow?: boolean;
  showScrollProgress?: boolean;
  eagerReveal?: boolean;
}

const { title, description, image, imageAlt, noindex, nofollow, showScrollProgress = false, eagerReveal = false } = Astro.props;

---

<BaseLayout
  title={title}
  description={description}
  image={image}
  imageAlt={imageAlt}
  noindex={noindex}
  nofollow={nofollow}
  eagerReveal={eagerReveal}
>
  <Header
    slot="header"
    position="fixed"
    shape="floating"
    variant="transparent"
    colorScheme="default"
    size="lg"
    showActiveState
    showCta={true}
    cta={{ label: 'Konsultasi Gratis', href: 'https://wa.me/6281328048030', icon: 'message-circle' }}
    showThemeSelector
    autoHide={false}
    scrollProgressPosition="top"
    invertOnReturn={false}
    showScrollProgress={showScrollProgress}
  />

  <main class="min-h-screen">
    <slot />
  </main>

  <Footer
    slot="footer"
    layout="columns"
    columns={3}
    background="secondary"
    tagline="Jasa Bore Pile Profesional di Pulau Jawa"
    copyright="© {year} {siteName}. Semua hak dilindungi."
    linkGroups={[
      {
        title: 'Layanan',
        links: [
          { label: 'Jasa Bore Pile', href: '/layanan' },
          { label: 'Straus Pile', href: '/layanan' },
          { label: 'Mini Crane', href: '/layanan' },
          { label: 'Survey & Konsultasi', href: '/contact' },
        ],
      },
      {
        title: 'Perusahaan',
        links: [
          { label: 'Tentang Kami', href: '/about' },
          { label: 'Portofolio', href: '/projects' },
          { label: 'Blog', href: '/blog' },
          { label: 'Kontak', href: '/contact' },
        ],
      },
    ]}
    legalLinks={[
      { label: 'Kebijakan Privasi', href: '/privacy' },
      { label: 'Syarat & Ketentuan', href: '/terms' },
    ]}
  />
</BaseLayout>
